@model mathiasBike.Models.HomeAdvanceViewModel
@{
    ViewData["Title"] = "BikeRoutes Safe";
}

@if (TempData["AdvanceMessage"] is string advanceMessage)
{
    <div class="alert alert-success advance-alert" role="alert">
        @advanceMessage
    </div>
}

<div class="dashboard-page">
    <section class="hero-banner">
        <div class="hero-copy">
            <span class="eyebrow">Avances académicos · BikeRoutes Safe</span>
            <h1>Un tablero visual para tus prácticas.</h1>
            <p>Los conceptos se muestran con tarjetas e indicadores visuales, y debajo tienes un formulario real para enviar tu avance.</p>
            <div class="hero-badges">
                <span class="hero-badge">Tarjetas visuales</span>
                <span class="hero-badge">Formulario activo</span>
                <span class="hero-badge">Diseño responsive</span>
            </div>
        </div>
        <div class="hero-panel">
            <div class="hero-panel-label">Resumen rápido</div>
            <div class="hero-panel-title">Dos bloques, ocho conceptos y un formulario de entrega</div>
            <div class="hero-panel-copy">La página está pensada como una mini presentación visual para mostrar el avance del proyecto sin depender de texto plano.</div>
            <div class="hero-metrics">
                <div>
                    <strong>4</strong>
                    <span>Temas del primer avance</span>
                </div>
                <div>
                    <strong>4</strong>
                    <span>Temas del segundo avance</span>
                </div>
                <div>
                    <strong>1</strong>
                    <span>Formulario de envío</span>
                </div>
            </div>
        </div>
    </section>

    <section class="practice-section" id="avance-uno">
        <div class="section-headline">
            <div>
                <span class="section-kicker">Primer avance</span>
                <h2>Primer avance visual</h2>
            </div>
            <p>La primera práctica se resume en cuatro bloques visuales que muestran el enfoque del proyecto.</p>
        </div>
        <div class="practice-grid visual-grid">
            <article class="practice-card theme-card">
                <div class="theme-icon web">W</div>
                <h3>Web</h3>
                <p>Interfaz responsive con jerarquía visual y composición limpia.</p>
                <span class="card-pill">UI / UX</span>
            </article>
            <article class="practice-card theme-card">
                <div class="theme-icon http">H</div>
                <h3>HTTP</h3>
                <p>Peticiones y respuestas mostradas como flujo de comunicación.</p>
                <span class="card-pill">Requests</span>
            </article>
            <article class="practice-card theme-card">
                <div class="theme-icon git">G</div>
                <h3>Git</h3>
                <p>Control de versiones con commits y ramas para registrar el avance.</p>
                <span class="card-pill">Versionado</span>
            </article>
            <article class="practice-card theme-card">
                <div class="theme-icon form">F</div>
                <h3>Formularios</h3>
                <p>Entrada de datos pensada para capturar información de usuario.</p>
                <span class="card-pill">Input</span>
            </article>
        </div>
    </section>

    <section class="practice-section practice-section-alt" id="avance-dos">
        <div class="section-headline">
            <div>
                <span class="section-kicker">Segundo avance</span>
                <h2>Base de datos, HTTP y estado de la aplicación</h2>
            </div>
            <p>El segundo bloque agrupa persistencia, aplicaciones web, métodos HTTP y estado de aplicación en tarjetas separadas.</p>
        </div>
        <div class="practice-grid practice-grid-two-columns visual-grid">
            <article class="practice-card practice-card-soft theme-card">
                <div class="theme-icon data">D</div>
                <h3>Base de datos + Redis</h3>
                <p>Persistencia y caché para guardar y recuperar información rápidamente.</p>
                <div class="tag-row">
                    <span class="card-pill">Base de Datos</span>
                    <span class="card-pill">Redis</span>
                </div>
            </article>
            <article class="practice-card practice-card-soft theme-card">
                <div class="theme-icon http">M</div>
                <h3>Aplicaciones web + HTTP</h3>
                <p>La app se organiza como una experiencia web que usa GET, POST, PUT y DELETE como acciones visibles.</p>
                <div class="tag-row">
                    <span class="card-pill">Aplicaciones web</span>
                    <span class="card-pill">GET</span>
                    <span class="card-pill">POST</span>
                    <span class="card-pill">PUT</span>
                    <span class="card-pill">DELETE</span>
                </div>
            </article>
            <article class="practice-card practice-card-soft theme-card">
                <div class="theme-icon session">S</div>
                <h3>Sesiones + cookies</h3>
                <p>Estado del usuario conservado entre peticiones sin perder el contexto.</p>
                <div class="tag-row">
                    <span class="card-pill">Sesiones</span>
                    <span class="card-pill">Cookies</span>
                </div>
            </article>
            <article class="practice-card practice-card-soft theme-card">
                <div class="theme-icon temp">T</div>
                <h3>TempData + ViewData</h3>
                <p>Mensajes temporales y datos de vista para comunicar pantallas entre sí.</p>
                <div class="tag-row">
                    <span class="card-pill">TempData</span>
                    <span class="card-pill">ViewData</span>
                </div>
            </article>
        </div>
    </section>

    <section class="practice-section form-section" id="avance-formulario">
        <div class="section-headline">
            <div>
                <span class="section-kicker">Formulario</span>
                <h2>Envía tu avance</h2>
            </div>
            <p>Un formulario real para registrar el avance del proyecto y demostrar el envío por HTTP POST.</p>
        </div>

        <div class="form-shell">
            <div class="form-aside">
                <div class="aside-badge">POST</div>
                <h3>Registro de práctica</h3>
                <p>Completa los campos y envía el formulario para dejar constancia del avance académico.</p>
                <ul class="aside-points">
                    <li>Validación básica en el servidor</li>
                    <li>Confirmación después de enviar</li>
                    <li>Diseño alineado con la página</li>
                </ul>
            </div>

            <form asp-action="Index" method="post" class="advance-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-grid">
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Tu nombre" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PracticaSeleccionada" class="form-label"></label>
                        <select asp-for="PracticaSeleccionada" class="form-select">
                            <option value="">Selecciona una práctica</option>
                            <option value="Primera práctica">Primera práctica</option>
                            <option value="Segunda práctica">Segunda práctica</option>
                        </select>
                        <span asp-validation-for="PracticaSeleccionada" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TemaPrincipal" class="form-label"></label>
                        <input asp-for="TemaPrincipal" class="form-control" placeholder="Tema que quieres mostrar" />
                        <span asp-validation-for="TemaPrincipal" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Comentario" class="form-label"></label>
                    <textarea asp-for="Comentario" class="form-control" rows="4" placeholder="Describe tu avance, capturas o notas importantes"></textarea>
                    <span asp-validation-for="Comentario" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="AceptaTerminos" class="form-check-input" />
                    <label asp-for="AceptaTerminos" class="form-check-label"></label>
                    <span asp-validation-for="AceptaTerminos" class="text-danger d-block"></span>
                </div>

                <button type="submit" class="btn btn-primary submit-btn">Enviar avance</button>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
