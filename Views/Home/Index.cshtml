@model mathiasBike.Models.HomeAdvanceViewModel
@{
    ViewData["Title"] = "BikeRoutes Safe";
}

@if (TempData["AdvanceMessage"] is string advanceMessage)
{
    <div class="alert alert-success advance-alert" role="alert">
        @advanceMessage
    </div>
}

<div class="dashboard-page">
    <section class="hero-banner">
        <div class="hero-copy">
            <span class="eyebrow">BikeRoutes Safe</span>
            <h1>Panel funcional para tus prácticas.</h1>
            <p>Accede a formularios, usa sesión y cookies, y registra avances desde la misma pantalla.</p>
            <div class="hero-badges">
                <span class="hero-badge">Sesión activa: @Model.VisitCount</span>
                <span class="hero-badge">Cookie: @Model.SavedPreference</span>
                <span class="hero-badge">Última carga: @Model.LastVisit</span>
            </div>
        </div>
        <div class="hero-panel">
            <div class="hero-panel-label">Acciones rápidas</div>
            <div class="hero-panel-title">Funciones reales del proyecto</div>
            <div class="hero-metrics">
                <div>
                    <strong>HTTP</strong>
                    <span>Demo interactiva</span>
                </div>
                <div>
                    <strong>POST</strong>
                    <span>Contacto y avance</span>
                </div>
                <div>
                    <strong>STATE</strong>
                    <span>Sesión y cookies</span>
                </div>
            </div>
        </div>
    </section>

    <section class="practice-section feature-section" id="accesos-rapidos">
        <div class="section-headline">
            <div>
                <span class="section-kicker">Accesos rápidos</span>
                <h2>Entra a las funciones</h2>
            </div>
        </div>
        <div class="feature-grid">
            <a class="feature-card" asp-controller="HttpDemo" asp-action="Index">
                <div class="theme-icon http">H</div>
                <div>
                    <h3>HTTP Demo</h3>
                    <p>GET y POST funcionando en vivo.</p>
                </div>
            </a>
            <a class="feature-card" asp-controller="Contacto" asp-action="Index">
                <div class="theme-icon form">C</div>
                <div>
                    <h3>Contacto</h3>
                    <p>Formulario con validación y POST.</p>
                </div>
            </a>
            <a class="feature-card" asp-controller="Reporte" asp-action="Crear">
                <div class="theme-icon temp">R</div>
                <div>
                    <h3>Reporte</h3>
                    <p>Envía un reporte y confirma el resultado.</p>
                </div>
            </a>
            <a class="feature-card" href="#estado-sesion">
                <div class="theme-icon session">S</div>
                <div>
                    <h3>Sesión / Cookies</h3>
                    <p>Guarda preferencia y contador de visitas.</p>
                </div>
            </a>
        </div>
    </section>

    <section class="practice-section practice-section-alt" id="estado-sesion">
        <div class="section-headline">
            <div>
                <span class="section-kicker">Sesión y cookies</span>
                <h2>Estado persistente en la página</h2>
            </div>
            <p>Esto funciona de verdad: la sesión cuenta visitas y la cookie guarda tu preferencia.</p>
        </div>
        <div class="state-grid">
            <article class="state-card">
                <span class="state-label">Visitas en esta sesión</span>
                <strong>@Model.VisitCount</strong>
                <p>Cada vez que entras a la home, el contador sube con <span>Session</span>.</p>
            </article>
            <article class="state-card">
                <span class="state-label">Preferencia guardada</span>
                <strong>@Model.SavedPreference</strong>
                <p>La selección queda guardada como cookie para la próxima visita.</p>
            </article>
            <article class="state-card">
                <span class="state-label">TempData</span>
                <strong>Activo</strong>
                <p>Los mensajes de confirmación aparecen después de enviar el formulario o guardar una preferencia.</p>
            </article>
            <article class="state-card">
                <span class="state-label">ViewData</span>
                <strong>En uso</strong>
                <p>Se mantiene el título y la información visual de las vistas secundarias.</p>
            </article>
        </div>

        <div class="state-actions">
            <form asp-action="GuardarPreferencia" method="post" class="state-form">
                @Html.AntiForgeryToken()
                <label for="rutaPreferida" class="form-label">Guardar preferencia en cookie</label>
                <div class="input-group">
                    <select id="rutaPreferida" name="rutaPreferida" class="form-select">
                        <option value="">Selecciona una opción</option>
                        <option value="Ruta universitaria">Ruta universitaria</option>
                        <option value="Ruta nocturna">Ruta nocturna</option>
                        <option value="Ruta express">Ruta express</option>
                    </select>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>

            <form asp-action="ReiniciarEstado" method="post" class="state-reset">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">Resetear sesión y cookie</button>
            </form>
        </div>
    </section>

    <section class="practice-section form-section" id="avance-formulario">
        <div class="section-headline">
            <div>
                <span class="section-kicker">Formulario</span>
                <h2>Envía un avance real</h2>
            </div>
            <p>El envío se procesa por POST y deja una confirmación con TempData.</p>
        </div>

        <div class="form-shell">
            <div class="form-aside">
                <div class="aside-badge">POST</div>
                <h3>Registro funcional</h3>
                <p>Este formulario demuestra validación, envío y confirmación sin depender de texto adicional.</p>
                <ul class="aside-points">
                    <li>Validación en el servidor</li>
                    <li>Confirmación con TempData</li>
                    <li>Datos de práctica persistentes</li>
                </ul>
            </div>

            <form asp-action="Index" method="post" class="advance-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-grid">
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Tu nombre" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PracticaSeleccionada" class="form-label"></label>
                        <select asp-for="PracticaSeleccionada" class="form-select">
                            <option value="">Selecciona una práctica</option>
                            <option value="Primera práctica">Primera práctica</option>
                            <option value="Segunda práctica">Segunda práctica</option>
                        </select>
                        <span asp-validation-for="PracticaSeleccionada" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TemaPrincipal" class="form-label"></label>
                        <input asp-for="TemaPrincipal" class="form-control" placeholder="Tema que quieres mostrar" />
                        <span asp-validation-for="TemaPrincipal" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Comentario" class="form-label"></label>
                    <textarea asp-for="Comentario" class="form-control" rows="4" placeholder="Describe tu avance, capturas o notas importantes"></textarea>
                    <span asp-validation-for="Comentario" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="AceptaTerminos" class="form-check-input" />
                    <label asp-for="AceptaTerminos" class="form-check-label"></label>
                    <span asp-validation-for="AceptaTerminos" class="text-danger d-block"></span>
                </div>

                <button type="submit" class="btn btn-primary submit-btn">Enviar avance</button>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
