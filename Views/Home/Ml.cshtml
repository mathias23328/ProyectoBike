@model grupomathias.Models.MlAnalysisViewModel

@{
    ViewData["Title"] = "ML Agent";
}

<section class="hero-shell platform-shell">
    <div class="hero-copy">
        <span class="eyebrow">Avance 3 · ML.NET + Agentic</span>
        <h1>Predicción de rutas seguras con ML.NET</h1>
        <p class="lead-copy">
            Usa un modelo de clasificación binaria en el servidor para estimar si una ruta es segura
            según tus preferencias de ciclovía, tráfico, iluminación y horario.
        </p>
    </div>

    <div class="planner-card">
        <div class="card-header-copy">
            <h2>Analiza una ruta con el agente</h2>
            <p>Llena los datos y observa la respuesta del modelo ML junto a la explicación del agente.</p>
        </div>

        <form asp-action="Ml" method="post" class="route-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div class="field-grid">
                <div class="form-floating">
                    <input asp-for="Request.Origin" class="form-control" placeholder="Centro histórico" />
                    <label asp-for="Request.Origin"></label>
                    <span asp-validation-for="Request.Origin" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Request.Destination" class="form-control" placeholder="Parque lineal" />
                    <label asp-for="Request.Destination"></label>
                    <span asp-validation-for="Request.Destination" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Request.DistanceKm" type="number" min="1" max="60" class="form-control" placeholder="8" />
                    <label asp-for="Request.DistanceKm"></label>
                    <span asp-validation-for="Request.DistanceKm" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <select asp-for="Request.RiderType" class="form-select">
                        <option value="">Selecciona una opción</option>
                        <option value="urbano">Urbano</option>
                        <option value="familiar">Familiar</option>
                        <option value="entrenamiento">Entrenamiento</option>
                    </select>
                    <label asp-for="Request.RiderType"></label>
                    <span asp-validation-for="Request.RiderType" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <select asp-for="Request.DepartureWindow" class="form-select">
                        <option value="">Selecciona una franja</option>
                        <option value="Mañana">Mañana</option>
                        <option value="Tarde">Tarde</option>
                        <option value="Noche">Noche</option>
                    </select>
                    <label asp-for="Request.DepartureWindow"></label>
                    <span asp-validation-for="Request.DepartureWindow" class="text-danger small"></span>
                </div>
            </div>

            <div class="preference-grid">
                <label class="preference-item">
                    <input asp-for="Request.PreferBikeLanes" class="form-check-input" />
                    <span>Priorizar ciclovías</span>
                </label>

                <label class="preference-item">
                    <input asp-for="Request.AvoidHighTraffic" class="form-check-input" />
                    <span>Evitar tráfico pesado</span>
                </label>

                <label class="preference-item">
                    <input asp-for="Request.PreferWellLitAreas" class="form-check-input" />
                    <span>Priorizar zonas bien iluminadas</span>
                </label>
            </div>

            <button type="submit" class="btn-plan">Ejecutar modelo</button>
        </form>
    </div>
</section>

@if (Model.Response is not null)
{
    <section class="insight-grid mt-3">
        <article class="insight-card result-card">
            <div class="result-header">
                <div>
                    <span class="card-kicker">Resultado ML</span>
                    <h2>@(Model.Response.IsSafeRoute ? "Ruta recomendada" : "Recomendación de revisión")</h2>
                </div>
                <div class="score-pill">Probabilidad @Model.Response.SafetyProbability:P0</div>
            </div>

            <p><strong>@Model.Response.Recommendation</strong></p>
            <p>@Model.Response.AgentReasoning</p>

            <div class="result-note">Score interno: @Model.Response.SafetyScore% · Id de ruta: @Model.Response.RouteId</div>
        </article>

        <article class="insight-card">
            <span class="card-kicker">Detalles del agente</span>
            <h2>Paso a paso del razonamiento ML</h2>
            <ul class="highlight-list">
                @foreach (var step in Model.Response.AgentSteps)
                {
                    <li><strong>@step.Name:</strong> @step.Detail</li>
                }
            </ul>
        </article>

        <article class="insight-card">
            <span class="card-kicker">Estado del modelo</span>
            <h2>Información operativa</h2>
            <p>@Model.Status.ModelState</p>
            <p>@Model.Status.CacheBackend</p>
            <p>Rutas registradas: @Model.Status.RecentRouteCount</p>
            <p>Última predicción: @Model.Status.LastPredictionSummary</p>
        </article>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
