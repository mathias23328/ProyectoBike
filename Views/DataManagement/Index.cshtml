@model IDictionary<string, object?>

@{
    ViewData["Title"] = "Gestión Integral de Datos";
}

<section class="hero-shell data-management-shell">
    <div class="hero-copy">
        <span class="eyebrow">Avance 3 · Data Management</span>
        <h1>Gestión completa de datos en la aplicación web</h1>
        <p class="lead-copy">
            Explora todos los mecanismos de almacenamiento: sesiones de usuario, cookies de navegador,
            ViewData para la vista actual, TempData para redirecciones y Redis Cache distribuida.
        </p>

        <div class="hero-metrics">
            <article>
                <strong>Sesiones</strong>
                <span>estado del usuario por solicitud</span>
            </article>
            <article>
                <strong>Cookies</strong>
                <span>almacenamiento persistente en el navegador</span>
            </article>
            <article>
                <strong>ViewData</strong>
                <span>datos para la vista actual</span>
            </article>
            <article>
                <strong>TempData</strong>
                <span>datos temporales entre redirecciones</span>
            </article>
            <article>
                <strong>Redis Cache</strong>
                <span>caché distribuida para alto rendimiento</span>
            </article>
            <article>
                <strong>HTTP Methods</strong>
                <span>GET, POST, PUT, DELETE para CRUD</span>
            </article>
            <article>
                <strong>Mapas</strong>
                <span>rutas de bicicleta en Lima</span>
            </article>
        </div>
    </div>

    <div class="planner-card">
        <div class="card-header-copy">
            <h2>Estado Actual</h2>
            <p>Información del almacenamiento de datos activo</p>
        </div>

        <div class="status-stack">
            <div class="status-chip">
                <strong>Hora actual:</strong> @Model["CurrentTime"]
            </div>
            <div class="status-chip">
                <strong>Sesión:</strong> @Model["SessionExample"]
            </div>
            <div class="status-chip">
                <strong>Cookie:</strong> @Model["CookieExample"]
            </div>
            <div class="status-chip">
                <strong>Caché:</strong> @Model["CacheExample"]
            </div>
        </div>
    </div>
</section>

<section class="insight-grid">
    <article class="insight-card">
        <span class="card-kicker">📌 Sesiones</span>
        <h2>Almacenamiento por sesión del usuario</h2>
        <p>Las sesiones persisten mientras el usuario está conectado. Se eliminan al cerrar la sesión.</p>
        <a href="@Url.Action("Sessions", "DataManagement")" class="btn-plan">Ir a Sesiones</a>
    </article>

    <article class="insight-card">
        <span class="card-kicker">🍪 Cookies</span>
        <h2>Almacenamiento en el navegador</h2>
        <p>Las cookies se guardan en el navegador y se envían con cada solicitud. Tienen fecha de expiración.</p>
        <a href="@Url.Action("Cookies", "DataManagement")" class="btn-plan">Ir a Cookies</a>
    </article>

    <article class="insight-card">
        <span class="card-kicker">👁️ ViewData</span>
        <h2>Datos para la vista actual</h2>
        <p>ViewData solo existe durante el renderizado de la vista actual. No persisten en redirecciones.</p>
        <a href="@Url.Action("ViewDataDemo", "DataManagement")" class="btn-plan">Ir a ViewData</a>
    </article>

    <article class="insight-card">
        <span class="card-kicker">⏱️ TempData</span>
        <h2>Datos temporales para redirecciones</h2>
        <p>TempData persiste a través de una redirección (típicamente para mensajes de éxito/error).</p>
        <a href="@Url.Action("TempDataDemo", "DataManagement")" class="btn-plan">Ir a TempData</a>
    </article>

    <article class="insight-card">
        <span class="card-kicker">⚡ Redis Cache</span>
        <h2>Caché distribuida de alto rendimiento</h2>
        <p>Redis guarda datos en caché con expiración configurable. Perfecto para datos que se leen mucho.</p>
        <a href="@Url.Action("Cache", "DataManagement")" class="btn-plan">Ir a Cache</a>
    </article>

    <article class="insight-card">
        <span class="card-kicker">📝 Formularios y Validación</span>
        <h2>Procesamiento de datos del usuario</h2>
        <p>Validación en cliente y servidor, con almacenamiento en múltiples canales.</p>
        <a href="@Url.Action("Forms", "DataManagement")" class="btn-plan">Ir a Formularios</a>
    </article>

    <article class="insight-card">
        <span class="card-kicker">🌐 Métodos HTTP</span>
        <h2>GET, POST, PUT, DELETE</h2>
        <p>Comprende los verbos HTTP principales para operaciones CRUD.</p>
        <a href="@Url.Action("HttpMethods", "DataManagement")" class="btn-plan">Ir a Métodos HTTP</a>
    </article>

    <article class="insight-card">
        <span class="card-kicker">🗺️ Mapas Interactivos</span>
        <h2>Rutas de bicicleta en Lima</h2>
        <p>Explora rutas populares con mapas interactivos usando Leaflet.js y OpenStreetMap.</p>
        <a href="@Url.Action("Maps", "DataManagement")" class="btn-plan">Ir a Mapas</a>
    </article>
</section>

<style>
    .data-management-shell {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .insight-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin: 3rem 0;
    }

    .insight-card {
        background: white;
        border-radius: 8px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .insight-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
    }

    .card-kicker {
        display: block;
        font-size: 0.875rem;
        color: #667eea;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .insight-card h2 {
        font-size: 1.5rem;
        margin: 0.5rem 0 1rem;
        color: #2d3748;
    }

    .insight-card p {
        color: #718096;
        margin-bottom: 1.5rem;
        line-height: 1.6;
    }

    .btn-plan {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        background: #667eea;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        transition: background 0.2s;
    }

    .btn-plan:hover {
        background: #764ba2;
    }

    .status-stack {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .status-chip {
        background: #f7fafc;
        border-left: 4px solid #667eea;
        padding: 1rem;
        border-radius: 4px;
        font-family: 'Courier New', monospace;
        font-size: 0.9rem;
    }

    .status-chip strong {
        color: #2d3748;
        display: block;
        margin-bottom: 0.25rem;
    }
</style>
