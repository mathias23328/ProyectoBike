@model mathiasBike.Models.ReporteRutaViewModel
@{
    ViewData["Title"] = "Reportar ruta";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1>Reportar ruta insegura</h1>
        <p class="text-muted">Formulario temático BikeRoutes Safe — validación del lado servidor.</p>

        <form asp-action="Crear" method="post" class="card p-4 shadow-sm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="NombreRuta" class="form-label"></label>
                <input asp-for="NombreRuta" class="form-control" placeholder="Ej: Ciclovía Universitaria" />
                <span asp-validation-for="NombreRuta" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NivelRiesgo" class="form-label"></label>
                <select asp-for="NivelRiesgo" class="form-select">
                    <option value="">-- Selecciona --</option>
                    <option value="Bajo">Bajo</option>
                    <option value="Medio">Medio</option>
                    <option value="Alto">Alto</option>
                </select>
                <span asp-validation-for="NivelRiesgo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Describe el peligro o incidente..."></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IncluirUbicacion" class="form-check-input" />
                <label asp-for="IncluirUbicacion" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-danger">Enviar reporte</button>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
